# ──────────────── Database ────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/jobmatch
REDIS_URL=redis://redis:6379/0
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobmatch

# ──────────────── API Keys ────────────────
GEMINI_API_KEY=your_gemini_key_here
JSEARCH_API_KEY=your_jsearch_key_here

# ──────────────── App Security ────────────────
SECRET_KEY=your_secret_key_here

# ──────────────── Deployment (set these on the server) ────────────────
# ALLOWED_ORIGINS=http://localhost:3000,http://<YOUR_VM_IP>
# VITE_API_URL=http://<YOUR_VM_IP>
# SQL_ECHO=false
